{
  "$schema": "https://www.schemastore.org/chrome-manifest",
  "manifest_version": 3,
  "name": "Text to Speech",
  "version": "1.1.0",
  "description": "Text to Speech",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "contextMenus",
    "tts"
  ]
}
